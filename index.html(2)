<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>GlobuFlow — Flow Without Friction</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=DM+Mono:ital,wght@0,300;0,400;0,500;1,300&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #000000;
  --surface: #080808;
  --surface2: #0f0f0f;
  --surface3: #141414;
  --border: rgba(255,255,255,0.06);
  --border2: rgba(255,255,255,0.12);
  --border3: rgba(255,255,255,0.2);
  --text: #ffffff;
  --text2: #888888;
  --text3: #444444;
  --text4: #222222;
  --blue: #3b82f6;
  --blue-dim: rgba(59,130,246,0.08);
  --blue-glow: rgba(59,130,246,0.15);
  --cyan: #06b6d4;
  --cyan-dim: rgba(6,182,212,0.08);
  --accent: rgba(255,255,255,0.9);
  --font-display: 'Playfair Display', serif;
  --font-body: 'Space Grotesk', sans-serif;
  --font-mono: 'DM Mono', monospace;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; }

body {
  font-family: var(--font-body);
  background: var(--bg);
  color: var(--text);
  overflow-x: hidden;
  cursor: none;
}

/* Custom cursor */
.cursor {
  position: fixed;
  width: 8px;
  height: 8px;
  background: white;
  border-radius: 50%;
  pointer-events: none;
  z-index: 9999;
  transition: transform 0.1s ease;
  mix-blend-mode: difference;
}
.cursor-ring {
  position: fixed;
  width: 32px;
  height: 32px;
  border: 0.5px solid rgba(255,255,255,0.4);
  border-radius: 50%;
  pointer-events: none;
  z-index: 9998;
  transition: transform 0.15s ease, width 0.2s, height 0.2s;
}

/* Noise texture overlay */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
  pointer-events: none;
  z-index: 1;
  opacity: 0.4;
}

/* NAV */
nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  padding: 1.25rem 3rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 0.5px solid transparent;
  transition: border-color 0.3s, background 0.3s;
}
nav.scrolled {
  background: rgba(0,0,0,0.9);
  border-color: var(--border);
  backdrop-filter: blur(12px);
}
.nav-logo {
  display: flex;
  align-items: center;
  gap: 10px;
  text-decoration: none;
}
.nav-brand {
  font-family: var(--font-body);
  font-size: 16px;
  font-weight: 700;
  color: white;
  letter-spacing: -0.3px;
}
.nav-links {
  display: flex;
  align-items: center;
  gap: 2.5rem;
  list-style: none;
}
.nav-links a {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--text2);
  text-decoration: none;
  letter-spacing: 2px;
  text-transform: uppercase;
  transition: color 0.2s;
}
.nav-links a:hover { color: white; }
.nav-cta {
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 2px;
  color: black;
  background: white;
  border: none;
  border-radius: 4px;
  padding: 8px 20px;
  cursor: none;
  transition: opacity 0.2s;
}
.nav-cta:hover { opacity: 0.85; }

/* HERO */
.hero {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 8rem 2rem 4rem;
  position: relative;
  overflow: hidden;
}

.hero-grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
  background-size: 60px 60px;
  mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 20%, transparent 100%);
}

.hero-glow {
  position: absolute;
  width: 600px;
  height: 600px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(59,130,246,0.06) 0%, transparent 70%);
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  pointer-events: none;
}

.hero-tag {
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 4px;
  color: var(--text3);
  text-transform: uppercase;
  margin-bottom: 2rem;
  display: flex;
  align-items: center;
  gap: 12px;
}
.hero-tag::before, .hero-tag::after {
  content: '';
  width: 40px;
  height: 0.5px;
  background: var(--border2);
}

.hero-title {
  font-family: var(--font-display);
  font-size: clamp(52px, 8vw, 96px);
  font-weight: 400;
  line-height: 1.0;
  letter-spacing: -2px;
  margin-bottom: 1.5rem;
  position: relative;
}

.hero-title em {
  font-style: italic;
  color: var(--text2);
}

.hero-sub {
  font-family: var(--font-body);
  font-size: 16px;
  color: var(--text2);
  max-width: 480px;
  line-height: 1.7;
  margin: 0 auto 3rem;
}

.hero-actions {
  display: flex;
  align-items: center;
  gap: 16px;
  justify-content: center;
  margin-bottom: 4rem;
}

.btn-primary {
  background: white;
  color: black;
  border: none;
  border-radius: 6px;
  padding: 12px 28px;
  font-family: var(--font-body);
  font-size: 14px;
  font-weight: 600;
  cursor: none;
  transition: opacity 0.2s, transform 0.2s;
}
.btn-primary:hover { opacity: 0.9; transform: translateY(-1px); }

.btn-secondary {
  background: transparent;
  color: var(--text2);
  border: 0.5px solid var(--border2);
  border-radius: 6px;
  padding: 12px 28px;
  font-family: var(--font-mono);
  font-size: 12px;
  letter-spacing: 2px;
  cursor: none;
  transition: border-color 0.2s, color 0.2s;
}
.btn-secondary:hover { border-color: var(--border3); color: white; }

.hero-stats {
  display: flex;
  align-items: center;
  gap: 3rem;
  justify-content: center;
}
.hero-stat { text-align: center; }
.hero-stat-num {
  font-family: var(--font-display);
  font-size: 32px;
  font-weight: 700;
  color: white;
  letter-spacing: -1px;
  display: block;
}
.hero-stat-label {
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--text3);
  letter-spacing: 2px;
  text-transform: uppercase;
}
.hero-stat-div {
  width: 0.5px;
  height: 40px;
  background: var(--border);
}

/* SECTION COMMON */
section {
  padding: 7rem 3rem;
  position: relative;
}
.section-label {
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 4px;
  color: var(--text3);
  text-transform: uppercase;
  margin-bottom: 1.5rem;
  display: flex;
  align-items: center;
  gap: 12px;
}
.section-label::before {
  content: '';
  width: 24px;
  height: 0.5px;
  background: var(--border2);
}
.section-title {
  font-family: var(--font-display);
  font-size: clamp(32px, 4vw, 52px);
  font-weight: 400;
  line-height: 1.1;
  letter-spacing: -1px;
  margin-bottom: 1.5rem;
}
.section-title em { font-style: italic; color: var(--text2); }
.section-sub {
  font-size: 15px;
  color: var(--text2);
  line-height: 1.7;
  max-width: 520px;
}

/* PROBLEM */
.problem {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 6rem;
  align-items: center;
  max-width: 1200px;
  margin: 0 auto;
}
.problem-cards {
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.problem-card {
  background: var(--surface);
  border: 0.5px solid var(--border);
  border-radius: 10px;
  padding: 1.25rem 1.5rem;
  display: grid;
  grid-template-columns: auto 1fr;
  gap: 1rem;
  align-items: center;
  transition: border-color 0.2s;
}
.problem-card:hover { border-color: var(--border2); }
.problem-card-num {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--text3);
  letter-spacing: 2px;
}
.problem-card-text { font-size: 14px; color: var(--text2); line-height: 1.5; }
.problem-card-text strong { color: white; font-weight: 500; }

/* SOLUTION */
.solution-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: var(--border);
  border-radius: 12px;
  overflow: hidden;
  margin-top: 4rem;
  max-width: 1000px;
  margin-left: auto;
  margin-right: auto;
}
.solution-card {
  background: var(--surface);
  padding: 2.5rem 2rem;
  position: relative;
  transition: background 0.2s;
}
.solution-card:hover { background: var(--surface2); }
.sol-icon {
  width: 36px;
  height: 36px;
  border-radius: 8px;
  border: 0.5px solid var(--border2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 1.5rem;
  font-size: 14px;
}
.sol-num {
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--text3);
  letter-spacing: 3px;
  margin-bottom: 0.75rem;
}
.sol-title {
  font-size: 18px;
  font-weight: 600;
  margin-bottom: 0.75rem;
  letter-spacing: -0.3px;
}
.sol-desc { font-size: 13px; color: var(--text2); line-height: 1.7; }

/* HOW IT WORKS */
.how-wrap { max-width: 900px; margin: 0 auto; }
.how-steps { margin-top: 4rem; display: flex; flex-direction: column; gap: 0; }
.how-step {
  display: grid;
  grid-template-columns: 60px 1fr;
  gap: 2rem;
  padding: 2rem 0;
  border-bottom: 0.5px solid var(--border);
  position: relative;
}
.how-step:last-child { border-bottom: none; }
.step-num {
  font-family: var(--font-display);
  font-size: 48px;
  color: var(--text4);
  font-weight: 700;
  letter-spacing: -2px;
  line-height: 1;
  padding-top: 4px;
}
.step-content {}
.step-tag {
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--text3);
  letter-spacing: 3px;
  text-transform: uppercase;
  margin-bottom: 0.5rem;
}
.step-title { font-size: 20px; font-weight: 600; margin-bottom: 0.75rem; letter-spacing: -0.3px; }
.step-desc { font-size: 14px; color: var(--text2); line-height: 1.7; }

/* WAITLIST MID */
.waitlist-mid {
  background: var(--surface);
  border-top: 0.5px solid var(--border);
  border-bottom: 0.5px solid var(--border);
  padding: 5rem 3rem;
  text-align: center;
}
.waitlist-mid-title {
  font-family: var(--font-display);
  font-size: clamp(28px, 4vw, 48px);
  font-weight: 400;
  letter-spacing: -1px;
  margin-bottom: 1rem;
}
.waitlist-mid-sub {
  font-size: 14px;
  color: var(--text2);
  margin-bottom: 2.5rem;
}
.waitlist-form {
  display: flex;
  gap: 10px;
  justify-content: center;
  max-width: 480px;
  margin: 0 auto;
}
.waitlist-input {
  flex: 1;
  background: var(--surface2);
  border: 0.5px solid var(--border2);
  border-radius: 6px;
  padding: 12px 16px;
  font-family: var(--font-body);
  font-size: 14px;
  color: white;
  outline: none;
  transition: border-color 0.2s;
}
.waitlist-input::placeholder { color: var(--text3); }
.waitlist-input:focus { border-color: var(--border3); }
.waitlist-btn {
  background: white;
  color: black;
  border: none;
  border-radius: 6px;
  padding: 12px 24px;
  font-family: var(--font-body);
  font-size: 14px;
  font-weight: 600;
  cursor: none;
  white-space: nowrap;
  transition: opacity 0.2s;
}
.waitlist-btn:hover { opacity: 0.9; }
.waitlist-note {
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--text3);
  letter-spacing: 2px;
  margin-top: 1rem;
}

/* TEAM */
.team-wrap { max-width: 1100px; margin: 0 auto; }
.team-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1px;
  background: var(--border);
  border-radius: 12px;
  overflow: hidden;
  margin-top: 4rem;
}
.team-card {
  background: var(--surface);
  padding: 1.75rem;
  transition: background 0.2s;
}
.team-card:hover { background: var(--surface2); }
.team-initials {
  width: 40px;
  height: 40px;
  border-radius: 8px;
  background: var(--surface2);
  border: 0.5px solid var(--border2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-mono);
  font-size: 12px;
  color: var(--text2);
  margin-bottom: 1rem;
}
.team-name { font-size: 14px; font-weight: 600; margin-bottom: 4px; }
.team-role { font-size: 12px; color: var(--text2); margin-bottom: 6px; }
.team-loc {
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--text3);
  letter-spacing: 1px;
}

/* WAITLIST BOTTOM */
.waitlist-bottom {
  max-width: 700px;
  margin: 0 auto;
  text-align: center;
  padding: 7rem 3rem;
}
.waitlist-bottom .section-title { margin-bottom: 1rem; }
.waitlist-bottom .section-sub { margin: 0 auto 2.5rem; }
.waitlist-bottom .waitlist-form { max-width: 500px; }

/* FOOTER */
footer {
  border-top: 0.5px solid var(--border);
  padding: 2.5rem 3rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.footer-brand {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 13px;
  font-weight: 600;
  color: var(--text2);
}
.team-linkedin {
  display: inline-block;
  margin-top: 10px;
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 1.5px;
  color: var(--text3);
  text-decoration: none;
  border: 0.5px solid var(--border);
  border-radius: 4px;
  padding: 4px 10px;
  transition: color 0.2s, border-color 0.2s;
}
.team-linkedin:hover { color: var(--text2); border-color: var(--border2); }
.footer-links {
  display: flex;
  gap: 2rem;
  list-style: none;
}
.footer-links a {
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--text3);
  text-decoration: none;
  letter-spacing: 2px;
  text-transform: uppercase;
  transition: color 0.2s;
}
.footer-links a:hover { color: var(--text2); }
.footer-copy {
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--text3);
  letter-spacing: 1px;
}

/* AI CHATBOT */
.chat-btn {
  position: fixed;
  bottom: 2rem;
  right: 2rem;
  width: 52px;
  height: 52px;
  background: white;
  border-radius: 50%;
  border: none;
  cursor: none;
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 0 1px rgba(255,255,255,0.1), 0 8px 32px rgba(0,0,0,0.8);
  transition: transform 0.2s;
}
.chat-btn:hover { transform: scale(1.08); }
.chat-btn svg { width: 20px; height: 20px; }

.chat-window {
  position: fixed;
  bottom: 5.5rem;
  right: 2rem;
  width: 360px;
  height: 480px;
  background: var(--surface);
  border: 0.5px solid var(--border2);
  border-radius: 16px;
  z-index: 200;
  display: none;
  flex-direction: column;
  overflow: hidden;
  box-shadow: 0 24px 64px rgba(0,0,0,0.8);
}
.chat-window.open { display: flex; }

.chat-header {
  padding: 1rem 1.25rem;
  border-bottom: 0.5px solid var(--border);
  display: flex;
  align-items: center;
  gap: 10px;
}
.chat-avatar {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: var(--surface2);
  border: 0.5px solid var(--border2);
  display: flex;
  align-items: center;
  justify-content: center;
}
.chat-info {}
.chat-name { font-size: 13px; font-weight: 600; }
.chat-status {
  font-family: var(--font-mono);
  font-size: 10px;
  color: #22c55e;
  letter-spacing: 1px;
}
.chat-close {
  margin-left: auto;
  background: none;
  border: none;
  color: var(--text2);
  cursor: none;
  font-size: 18px;
  line-height: 1;
}

.chat-messages {
  flex: 1;
  overflow-y: auto;
  padding: 1.25rem;
  display: flex;
  flex-direction: column;
  gap: 12px;
  scrollbar-width: thin;
  scrollbar-color: var(--border2) transparent;
}

.msg {
  max-width: 85%;
  padding: 10px 14px;
  border-radius: 12px;
  font-size: 13px;
  line-height: 1.5;
}
.msg.bot {
  background: var(--surface2);
  border: 0.5px solid var(--border);
  color: var(--text);
  align-self: flex-start;
  border-bottom-left-radius: 4px;
}
.msg.user {
  background: white;
  color: black;
  align-self: flex-end;
  border-bottom-right-radius: 4px;
}
.msg.typing { color: var(--text2); font-style: italic; }

.chat-suggestions {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  padding: 0 1.25rem 0.75rem;
}
.suggestion {
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 1px;
  color: var(--text2);
  border: 0.5px solid var(--border2);
  border-radius: 99px;
  padding: 4px 12px;
  cursor: none;
  transition: border-color 0.2s, color 0.2s;
  background: none;
}
.suggestion:hover { border-color: var(--border3); color: white; }

.chat-input-row {
  padding: 0.75rem 1.25rem;
  border-top: 0.5px solid var(--border);
  display: flex;
  gap: 8px;
  align-items: center;
}
.chat-input {
  flex: 1;
  background: var(--surface2);
  border: 0.5px solid var(--border);
  border-radius: 8px;
  padding: 8px 12px;
  font-family: var(--font-body);
  font-size: 13px;
  color: white;
  outline: none;
}
.chat-input::placeholder { color: var(--text3); }
.chat-send {
  background: white;
  color: black;
  border: none;
  border-radius: 8px;
  padding: 8px 14px;
  font-size: 13px;
  font-weight: 600;
  cursor: none;
}

/* Diamond i-dot */
.i-wrap {
  position: relative;
  display: inline-block;
}
.i-dot-diamond {
  position: absolute;
  top: -0.12em;
  left: 50%;
  transform: translateX(-50%) rotate(45deg);
  width: 0.18em;
  height: 0.18em;
  background: white;
  display: block;
  pointer-events: none;
}
.hero-title em .i-dot-diamond {
  background: var(--text2);
}

/* Brand network */
.brand-network {
  width: 100%;
  max-width: 680px;
  margin: 0 auto 2.5rem;
}
.brand-network-inner {
  display: grid;
  grid-template-columns: 140px 1fr 140px;
  align-items: center;
  gap: 0;
  height: 180px;
}
.brand-nodes {
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.brand-nodes.right { align-items: flex-end; }
.brand-node {
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 1.5px;
  color: var(--text3);
  border: 0.5px solid var(--border);
  border-radius: 4px;
  padding: 5px 10px;
  background: var(--surface);
  transition: color 0.2s, border-color 0.2s;
  white-space: nowrap;
}
.brand-node:hover { color: var(--text2); border-color: var(--border2); }
.network-lines {
  width: 100%;
  height: 180px;
}
.network-label {
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--text3);
  letter-spacing: 2px;
  text-align: center;
  margin-top: 0.75rem;
  text-transform: uppercase;
}

/* ANIMATIONS */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(24px); }
  to { opacity: 1; transform: translateY(0); }
}
@keyframes pulse-dot {
  0%, 100% { opacity: 0.3; } 50% { opacity: 1; }
}
.fade-up { animation: fadeUp 0.8s ease forwards; opacity: 0; }
.delay-1 { animation-delay: 0.1s; }
.delay-2 { animation-delay: 0.2s; }
.delay-3 { animation-delay: 0.35s; }
.delay-4 { animation-delay: 0.5s; }
.delay-5 { animation-delay: 0.65s; }

/* SCROLLBAR */
::-webkit-scrollbar { width: 4px; }
