<script>
// Cursor
const cursor = document.getElementById('cursor');
const ring = document.getElementById('cursorRing');
let mx = 0, my = 0, rx = 0, ry = 0;
document.addEventListener('mousemove', e => {
  mx = e.clientX; my = e.clientY;
  cursor.style.left = mx - 4 + 'px';
  cursor.style.top = my - 4 + 'px';
});
function animRing() {
  rx += (mx - rx) * 0.12;
  ry += (my - ry) *.12;
  ring.style.left = rx - 16 + 'px';
  ring.style.top = ry - 16 + 'px';
  requestAnimationFrame(animRing);
}
animRing();

// Nav scroll
window.addEventListener('scroll', () => {
  document.getElementById('nav').classList.toggle('scrolled', window.scrollY > 40);
});

// Scroll to waitlist
function scrollToWaitlist() {
  document.getElementById('waitlist').scrollIntoView({ behavior: 'smooth' });
}

// Waitlist
const waitlistEmails = new Set();
function joinWaitlist(source) {
  const input = document.getElementById(source === 'mid' ? 'mid-email' : 'bottom-email');
  const msg = document.getElementById(source === 'mid' ? 'mid-msg' : 'bottom-msg');
  const email = input.value.trim();
  if (!email || !email.includes('@')) {
    msg.textContent = 'Please enter a valid email.';
    msg.style.color = '#ef4444';
    return;
  }
  if (waitlistEmails.has(email)) {
    msg.textContent = "You're already on the list.";
    msg.style.color = '#888';
    return;
  }
  waitlistEmails.add(email);
  input.value = '';
  msg.textContent = "You're on the list. We'll be in touch soon.";
  msg.style.color = '#22c55e';
  setTimeout(() => msg.textContent = '', 5000);
}

// Chat
let chatOpen = false;
function toggleChat() {
  chatOpen = !chatOpen;
  document.getElementById('chatWindow').classList.toggle('open', chatOpen);
}

const responses = {
  'what is globuflow': "GlobuFlow is a supply chain OS for independent ecommerce brands. We connect manufacturers, suppliers, and warehouses into one AI-powered dashboard — giving brands full visibility and control over their operations. Think of us as the missing infrastructure layer between your brand and your supply chain.",
  'how does ai verification work': "Our AI verification engine analyses every supplier before they connect to your supply chain. It scores them on four dimensions: document authenticity, business legitimacy, compliance risk, and supply chain reliability. You get a trust score for every supplier — so you know exactly who you're working with before any connection is made.",
  'how do i join the waitlist': "Just scroll down to the waitlist section and enter your email! We're onboarding our first 10 beta brands with free access, direct founder input, and a say in how the product gets built. Or I can take your email right here — just type it in.",
  'what is the pricing': "We're launching with three tiers: Starter at $29/month, Growth at $99/month, and Scale at $249/month. Our first 10 beta brands get free access during the beta period. We're priced well below the enterprise tools (which start at $2,500/month) because we're built for independent brands, not Fortune 500 companies.",
  'who is the team': "GlobuFlow was founded by Aditya Turki (CEO, Melbourne), Zeting Justin Chen (COO, New York), and Rinta Seto (Chief AI Officer, UK). We have a distributed team of 8 across Australia, Singapore, India, and the UK. We're a remote-first team building global infrastructure.",
  'when does it launch': "We're targeting a launch in November 2026. We're currently building the product and onboarding our first beta brands. Join the waitlist to be among the first to get access.",
  'default': "That's a great question. GlobuFlow is still being built — we're in pre-launch right now. For specific questions, the best way to get in touch is to join our waitlist and we'll reach out directly. Is there anything else I can help you with?"
};

function askQuestion(q) {
  const suggestions = document.getElementById('suggestions');
  suggestions.style.display = 'none';
  addMsg(q, 'user');
  setTimeout(() => {
    const key = Object.keys(responses).find(k => q.toLowerCase().includes(k.split(' ')[0]) || k.split(' ').some(w => q.toLowerCase().includes(w)));
    addMsg(key ? responses[key] : responses['default'], 'bot');
  }, 600);
}

function sendChat() {
  const input = document.getElementById('chatInput');
  const q = input.value.trim();
  if (!q) return;
  input.value = '';
  document.getElementById('suggestions').style.display = 'none';
  addMsg(q, 'user');
  const typingId = 'typing-' + Date.now();
  const msgs = document.getElementById('chatMessages');
  const typing = document.createElement('div');
  typing.className = 'msg bot typing';
  typing.id = typingId;
  typing.textContent = 'Thinking...';
  msgs.appendChild(typing);
  msgs.scrollTop = msgs.scrollHeight;
  setTimeout(() => {
    document.getElementById(typingId)?.remove();
    const qLower = q.toLowerCase();
    const key = Object.keys(responses).find(k => k !== 'default' && k.split(' ').filter(w => w.length > 3).some(w => qLower.includes(w)));
    addMsg(key ? responses[key] : responses['default'], 'bot');
  }, 1000);
}

function addMsg(text, type) {
  const msgs = document.getElementById('chatMessages');
  const div = document.createElement('div');
  div.className = 'msg ' + type;
  div.textContent = text;
  msgs.appendChild(div);
  msgs.scrollTop = msgs.scrollHeight;
}

// Intersection observer for scroll animations
const observer = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      e.target.style.opacity = '1';
      e.target.style.transform = 'translateY(0)';
    }
  });
}, { threshold: 0.1 });

document.querySelectorAll('.problem-card, .solution-card, .how-step, .team-card').forEach(el => {
  el.style.opacity = '0';
  el.style.transform = 'translateY(20px)';
  el.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
  observer.observe(el);
});
</script>
</body>
</html>
